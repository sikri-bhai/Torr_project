# target to preprocess a source file
tracker/main.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\tracker.dir\build.make CMakeFiles/tracker.dir/tracker/main.cpp.i
.PHONY : tracker/main.cpp.i

tracker/main.s: tracker/main.cpp.s
.PHONY : tracker/main.s

# target to generate assembly for a file
tracker/main.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\tracker.dir\build.make CMakeFiles/tracker.dir/tracker/main.cpp.s
.PHONY : tracker/main.cpp.s

